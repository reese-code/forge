{% stylesheet %}
  .logo-with-text {
    --lwt-gap: var(--content-gap);
  }

  /* Content container width options using viewport width */
  .logo-with-text__container--three-fourths {
    max-width: 75vw;
  }

  .logo-with-text__container--half {
    max-width: 50vw;
  }

  .logo-with-text__container--two-thirds {
    max-width: 67vw;
  }

  .logo-with-text__container--one-third {
    max-width: 33vw;
  }

  .logo-with-text__container--full {
    max-width: 100vw;
  }

  /* Content positioning options */
  .logo-with-text__wrapper--left {
    margin-left: 0;
    margin-right: auto;
  }

  .logo-with-text__wrapper--center {
    margin-left: auto;
    margin-right: auto;
  }

  .logo-with-text__wrapper--right {
    margin-left: auto;
    margin-right: 0;
  }

  /* Logo height control - fit to natural size with max height */
  .logo-with-text__logo-wrap img,
  .logo-with-text__logo-wrap svg {
    display: block;
    width: auto;
    height: auto;
    max-height: var(--logo-max-height);
    max-width: 100%;
  }

  /* Mobile logo height */
  @media screen and (max-width: 749px) {
    .logo-with-text__logo-wrap img,
    .logo-with-text__logo-wrap svg {
      max-height: var(--logo-max-height-mobile);
    }
  }

  /* Side layout: logo sits beside paragraph */
  .logo-with-text--side {
    display: flex;
    align-items: flex-start;
    gap: var(--lwt-gap);
  }

  .logo-with-text--side .logo-with-text__logo-wrap {
    flex-shrink: 0;
    margin-top: 0;
  }

  .logo-with-text--side .logo-with-text__body {
    flex: 1;
    min-width: 0;
  }

  .logo-with-text--side .logo-with-text__body > :first-child {
    margin-top: 0;
  }

  /* Wrap layout: paragraph flows around the logo */
  .logo-with-text--wrap .logo-with-text__logo-wrap {
    float: left;
    margin-right: var(--lwt-gap);
    margin-bottom: 0.5rem;
  }

  .logo-with-text--wrap .logo-with-text__body::after {
    content: '';
    display: table;
    clear: both;
  }

  /* Mobile responsive behavior */
  @media screen and (max-width: 749px) {
    /* Only side layout becomes stacked on mobile, wrap layout continues to work */
    .logo-with-text--side {
      display: block;
    }

    .logo-with-text--side .logo-with-text__logo-wrap {
      margin-bottom: var(--lwt-gap);
    }

    .logo-with-text__container--three-fourths,
    .logo-with-text__container--two-thirds,
    .logo-with-text__container--half,
    .logo-with-text__container--one-third {
      max-width: 100%;
    }
  }
{% endstylesheet %}

{%- liquid
  assign container_width_class = 'logo-with-text__container--' | append: section.settings.content_width
  assign position_class = 'logo-with-text__wrapper--' | append: section.settings.content_position
  assign layout_class     = 'logo-with-text--' | append: section.settings.text_layout
-%}

<div
  class="section section--{{ section.settings.section_width }} spacing-style"
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    {%- render 'border-override', settings: section.settings -%}
  "
>
  <div class="logo-with-text {{ layout_class }} {{ container_width_class }} {{ position_class }}" style="--logo-max-height: {{ section.settings.logo_height }}px; --logo-max-height-mobile: {{ section.settings.logo_height_mobile }}px; --content-gap: {{ section.settings.content_gap }}px;">

    {%- if section.settings.logo != blank or section.settings.icon != blank -%}
      <div class="logo-with-text__logo-wrap">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_alt = section.settings.logo.alt | default: section.settings.heading | default: 'Logo' -%}
          {{ section.settings.logo | image_url: width: 800 | image_tag: loading: 'lazy', widths: '200, 400, 600, 800', alt: logo_alt }}
        {%- elsif section.settings.icon != blank -%}
          {%- assign icon_alt = section.settings.icon.alt | default: section.settings.heading | default: 'Icon' -%}
          {{ section.settings.icon | image_url: width: 400 | image_tag: loading: 'lazy', widths: '100, 200, 300, 400', alt: icon_alt }}
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="logo-with-text__body">
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="{{ section.settings.heading_size }}" style="margin-top:0;">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "t:names.logo_with_text",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Logo / Icon"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Upload a logo. If both logo and icon are set, logo takes priority."
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon image",
      "info": "Use a small icon instead of a full logo."
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo / icon height (desktop)",
      "info": "Height in pixels. Width will be automatic to maintain aspect ratio.",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Logo / icon height (mobile)",
      "info": "Height in pixels for mobile devices. Width will be automatic to maintain aspect ratio.",
      "min": 15,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "info": "Controls the width of the entire content block.",
      "options": [
        { "value": "three-fourths", "label": "Three-fourths (75%)" },
        { "value": "two-thirds",    "label": "Two-thirds (67%)" },
        { "value": "half",          "label": "Half (50%)" },
        { "value": "one-third",     "label": "One-third (33%)" },
        { "value": "full",          "label": "Full width (100%)" }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "info": "Controls the horizontal positioning of the entire content block.",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_layout",
      "label": "Paragraph position",
      "options": [
        { "value": "side", "label": "Beside logo (side by side)" },
        { "value": "wrap", "label": "Wraps around logo" }
      ],
      "default": "side",
      "info": "Choose how text is positioned relative to the logo. Side layout stacks on mobile, wrap layout works on all devices."
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Gap between logo and content",
      "info": "Controls the spacing between the logo and text content.",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built on one principle."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "p",  "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h3", "label": "Medium" },
        { "value": "h2", "label": "Large" },
        { "value": "h1", "label": "Extra large" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Make it right or don't make it at all. No shortcuts, no filler — just products crafted with the kind of integrity the name demands.</p>"
    },
    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:names.logo_with_text",
      "category": "t:categories.storytelling",
      "settings": {
        "logo_height": 60,
        "logo_height_mobile": 40,
        "content_width": "full",
        "content_position": "left",
        "content_gap": 30,
        "text_layout": "side",
        "heading": "Built on one principle.",
        "text": "<p>Make it right or don't make it at all. No shortcuts, no filler — just products crafted with the kind of integrity the name demands.</p>",
        "padding-block-start": 40,
        "padding-block-end": 40
      }
    }
  ]
}
{% endschema %}
