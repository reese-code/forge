{% stylesheet %}
  .logo-with-text {
    --lwt-gap: 2rem;
  }

  /* Logo size options on desktop */
  .logo-with-text__logo-wrap--three-fourths {
    width: 75%;
  }

  .logo-with-text__logo-wrap--half {
    width: 50%;
  }

  .logo-with-text__logo-wrap--one-third {
    width: 33.333%;
  }

  .logo-with-text__logo-wrap--full {
    width: 100%;
  }

  /* Side layout: logo sits beside paragraph */
  .logo-with-text--side {
    display: flex;
    align-items: flex-start;
    gap: var(--lwt-gap);
  }

  .logo-with-text--side .logo-with-text__logo-wrap {
    flex-shrink: 0;
  }

  .logo-with-text--side .logo-with-text__body {
    flex: 1;
    min-width: 0;
  }

  /* Wrap layout: paragraph flows around the logo */
  .logo-with-text--wrap .logo-with-text__logo-wrap {
    float: left;
    margin-right: var(--lwt-gap);
    margin-bottom: 0.5rem;
  }

  .logo-with-text--wrap .logo-with-text__body::after {
    content: '';
    display: table;
    clear: both;
  }

  /* Logo / icon image */
  .logo-with-text__logo-wrap img,
  .logo-with-text__logo-wrap svg {
    display: block;
    max-width: 100%;
    height: auto;
  }

  /* Text */
  .logo-with-text__body {
    line-height: 1.6;
  }

  /* Mobile — always full width, always stacked */
  @media screen and (max-width: 749px) {
    .logo-with-text--side,
    .logo-with-text--wrap {
      display: block;
    }

    .logo-with-text--side .logo-with-text__logo-wrap,
    .logo-with-text--wrap .logo-with-text__logo-wrap {
      float: none;
      width: 100% !important;
      margin-right: 0;
      margin-bottom: var(--lwt-gap);
    }
  }
{% endstylesheet %}

{%- liquid
  assign logo_width_class = 'logo-with-text__logo-wrap--' | append: section.settings.logo_width
  assign layout_class     = 'logo-with-text--' | append: section.settings.text_layout
-%}

<div
  class="section section--{{ section.settings.section_width }} spacing-style"
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    {%- render 'border-override', settings: section.settings -%}
  "
>
  <div class="logo-with-text {{ layout_class }}">

    {%- if section.settings.logo != blank or section.settings.icon != blank -%}
      <div class="logo-with-text__logo-wrap {{ logo_width_class }}">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_alt = section.settings.logo.alt | default: section.settings.heading | default: 'Logo' -%}
          {{ section.settings.logo | image_url: width: 800 | image_tag: loading: 'lazy', widths: '200, 400, 600, 800', alt: logo_alt }}
        {%- elsif section.settings.icon != blank -%}
          {%- assign icon_alt = section.settings.icon.alt | default: section.settings.heading | default: 'Icon' -%}
          {{ section.settings.icon | image_url: width: 400 | image_tag: loading: 'lazy', widths: '100, 200, 300, 400', alt: icon_alt }}
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="logo-with-text__body">
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="{{ section.settings.heading_size }}" style="margin-top:0;">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "t:names.logo_with_text",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Logo / Icon"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Upload a logo. If both logo and icon are set, logo takes priority."
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon image",
      "info": "Use a small icon instead of a full logo."
    },
    {
      "type": "select",
      "id": "logo_width",
      "label": "Logo / icon width (desktop)",
      "info": "On mobile this is always full width.",
      "options": [
        { "value": "three-fourths", "label": "Three-fourths (75%)" },
        { "value": "half",          "label": "Half (50%)" },
        { "value": "one-third",     "label": "One-third (33%)" },
        { "value": "full",          "label": "Full width (100%)" }
      ],
      "default": "half"
    },
    {
      "type": "header",
      "content": "Text layout"
    },
    {
      "type": "select",
      "id": "text_layout",
      "label": "Paragraph position",
      "options": [
        { "value": "side", "label": "Beside logo (side by side)" },
        { "value": "wrap", "label": "Wraps around logo" }
      ],
      "default": "side",
      "info": "On mobile the paragraph always appears below the logo."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built on one principle."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "p",  "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h3", "label": "Medium" },
        { "value": "h2", "label": "Large" },
        { "value": "h1", "label": "Extra large" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Make it right or don't make it at all. No shortcuts, no filler — just products crafted with the kind of integrity the name demands.</p>"
    },
    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:names.logo_with_text",
      "category": "t:categories.storytelling",
      "settings": {
        "logo_width": "half",
        "text_layout": "side",
        "heading": "Built on one principle.",
        "text": "<p>Make it right or don't make it at all. No shortcuts, no filler — just products crafted with the kind of integrity the name demands.</p>",
        "padding-block-start": 40,
        "padding-block-end": 40
      }
    }
  ]
}
{% endschema %}
