<!-- Custom Fonts CSS Variables -->
<style>
  :root {
    /* Custom font variables */
    {% if settings.custom_font_body == 'neue_montreal' %}
      --custom-font-body: 'Neue Montreal', var(--font-paragraph--family);
    {% elsif settings.custom_font_body == 'pp_neue_machina' %}
      --custom-font-body: 'PP Neue Machina', var(--font-paragraph--family);
    {% else %}
      --custom-font-body: var(--font-paragraph--family);
    {% endif %}

    {% if settings.custom_font_headings == 'pp_neue_machina' %}
      --custom-font-headings: 'PP Neue Machina', var(--font-heading--family);
    {% elsif settings.custom_font_headings == 'neue_montreal' %}
      --custom-font-headings: 'Neue Montreal', var(--font-heading--family);
    {% else %}
      --custom-font-headings: var(--font-heading--family);
    {% endif %}
  }

  /* Apply custom fonts when selected */
  {% if settings.custom_font_body != 'default' %}
  .custom-font-body,
  .custom-font-body * {
    font-family: var(--custom-font-body) !important;
  }
  {% endif %}

  {% if settings.custom_font_headings != 'default' %}
  .custom-font-headings,
  .custom-font-headings h1,
  .custom-font-headings h2,
  .custom-font-headings h3,
  .custom-font-headings h4,
  .custom-font-headings h5,
  .custom-font-headings h6,
  .custom-font-headings .h1,
  .custom-font-headings .h2,
  .custom-font-headings .h3,
  .custom-font-headings .h4,
  .custom-font-headings .h5,
  .custom-font-headings .h6 {
    font-family: var(--custom-font-headings) !important;
  }
  {% endif %}

  /* Utility classes for direct font application */
  .font-neue-montreal {
    font-family: 'Neue Montreal', var(--font-paragraph--family) !important;
  }

  .font-pp-neue-machina {
    font-family: 'PP Neue Machina', var(--font-paragraph--family) !important;
  }
</style>
